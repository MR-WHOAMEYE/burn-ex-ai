# Burn-Ex AI — Express Gateway Environment Variables
# Copy this file to .env and fill in your values

PORT=8080
NODE_ENV=development

# Gemini Multimodal Live API
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash-exp

# Spotify API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/api/spotify/callback

# MongoDB Atlas Connection String
MONGO_URI=mongodb://localhost:27017/burn-ex

# Redis (required for Socket.IO adapter in production)
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK service account key path
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk-key.json

# Python FastAPI AI Service URL
AI_SERVICE_URL=http://localhost:8000

# WhatsApp Cloud API (Meta Business)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173
